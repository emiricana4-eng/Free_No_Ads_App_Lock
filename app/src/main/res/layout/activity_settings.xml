<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F4F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- PIN Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PIN"
            android:textSize="12sp"
            android:textColor="#888888"
            android:textStyle="bold"
            android:paddingHorizontal="4dp"
            android:paddingBottom="6dp"
            android:paddingTop="8dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Change PIN -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Change PIN"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A2E"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Update your unlock PIN"
                            android:textSize="13sp"
                            android:textColor="#666666"/>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnChangePin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Change"
                        android:backgroundTint="#1565C0"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

                <!-- Recovery Code -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Recovery Code"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A2E"/>
                        <TextView
                            android:id="@+id/tvRecoveryStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No recovery code set"
                            android:textSize="13sp"
                            android:textColor="#666666"/>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnGenerateRecovery"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Generate"
                        android:backgroundTint="#1565C0"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Re-lock Delay -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BEHAVIOUR"
            android:textSize="12sp"
            android:textColor="#888888"
            android:textStyle="bold"
            android:paddingHorizontal="4dp"
            android:paddingBottom="6dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Re-lock Delay"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Grace period before re-locking"
                        android:textSize="13sp"
                        android:textColor="#666666"/>
                </LinearLayout>

                <Spinner
                    android:id="@+id/spinnerRelockDelay"
                    android:layout_width="140dp"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Security -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SECURITY"
            android:textSize="12sp"
            android:textColor="#888888"
            android:textStyle="bold"
            android:paddingHorizontal="4dp"
            android:paddingBottom="6dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Uninstall Protection"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Prevent App Lock from being removed"
                        android:textSize="13sp"
                        android:textColor="#666666"/>
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchUninstallProtection"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
